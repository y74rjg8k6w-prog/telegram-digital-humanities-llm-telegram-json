BOT_TOKEN=123456:replace_me
WEB_APP_URL=https://your-ngrok-or-domain.example

# Optional. If absent, the app still generates local analytics without LLM text.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional Supabase persistence for saved analyses.
# Use the project URL and anon/service key from Supabase Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=
SUPABASE_TABLE=analyses
TELEGRAM_WEBHOOK_SECRET=replace_with_random_secret
